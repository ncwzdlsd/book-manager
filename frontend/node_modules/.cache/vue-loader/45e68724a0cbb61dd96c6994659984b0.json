-icon><Calendar /></el-icon>\r\n              <span>我的预约</span>\r\n            </el-menu-item>\r\n            \r\n            <el-menu-item index=\"borrow\">\r\n              <el-icon><Document /></el-icon>\r\n              <span>我的借阅</span>\r\n            </el-menu-item>\r\n            \r\n            <el-menu-item index=\"book\">\r\n              <el-icon><Reading /></el-icon>\r\n              <span>图书大厅</span>\r\n            </el-menu-item>\r\n            \r\n            <el-menu-item index=\"notice\">\r\n              <el-icon><Bell /></el-icon>\r\n              <span>我的通知</span>\r\n            </el-menu-item>\r\n            \r\n            <el-menu-item index=\"suggestion\">\r\n              <el-icon><ChatDotRound /></el-icon>\r\n              <span>我的建议</span>\r\n            </el-menu-item>\r\n          </el-menu>\r\n        </el-aside>\r\n\r\n        <!-- 主内容区域 -->\r\n        <el-main class=\"main-content\">\r\n          <router-view />\r\n        </el-main>\r\n      </el-container>\r\n    </el-container>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { Calendar, Document, Reading, Bell, ChatDotRound } from '@element-plus/icons-vue'\r\n\r\nexport default {\r\n  name: 'ReaderHome',\r\n  components: {\r\n    Calendar,\r\n    Document,\r\n    Reading,\r\n    Bell,\r\n    ChatDotRound\r\n  },\r\n  data() {\r\n    return {\r\n      activeMenu: 'reservation'\r\n    }\r\n  },\r\n  computed: {\r\n    userInfo() {\r\n      const userInfo = localStorage.getItem('userInfo')\r\n      return userInfo ? JSON.parse(userInfo) : {}\r\n    }\r\n  },\r\n  methods: {\r\n    handleMenuSelect(key) {\r\n      this.activeMenu = key\r\n      this.$router.push(`/reader/${key}`)\r\n    },\r\n    handleLogout() {\r\n      localStorage.removeItem('userInfo')\r\n      localStorage.removeItem('token')\r\n      this.$store.dispatch('logout')\r\n      this.$router.push('/login')\r\n    }\r\n  },\r\n  watch: {\r\n    $route(to) {\r\n      // 根据当前路由更新菜单激活状态\r\n      const path = to.path\r\n      if (path.includes('/reader/')) {\r\n        const menuKey = path.split('/reader/')[1]\r\n        this.activeMenu = menuKey\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    // 根据当前路由设置菜单激活状态\r\n    const path = this.$route.path\r\n    if (path.includes('/reader/')) {\r\n      const menuKey = path.split('/reader/')[1]\r\n      this.activeMenu = menuKey\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.reader-home {\r\n  height: 100vh;\r\n}\r\n\r\n.header {\r\n  background-color: #409eff;\r\n  color: white;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 0 20px;\r\n}\r\n\r\n.header-left h2 {\r\n  margin: 0;\r\n  color: white;\r\n}\r\n\r\n.header-right {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n}\r\n\r\n.user-info {\r\n  color: white;\r\n  font-size: 14px;\r\n}\r\n\r\n.sidebar {\r\n  background-color: #545c64;\r\n}\r\n\r\n.menu {\r\n  border-right: none;\r\n}\r\n\r\n.main-content {\r\n  background-color: #f5f5f5;\r\n  padding: 20px;\r\n}\r\n\r\n.el-menu-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n}\r\n</style> "]}]}