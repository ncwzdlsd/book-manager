ervation.vue","sourceRoot":"","sourcesContent":["<template>\r\n  <div class=\"reservation-page\">\r\n    <div class=\"page-header\">\r\n      <h2>预约管理</h2>\r\n      <el-button type=\"primary\" @click=\"refreshData\">刷新</el-button>\r\n    </div>\r\n\r\n    <!-- 搜索和筛选 -->\r\n    <el-card class=\"search-card\">\r\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\r\n        <el-form-item label=\"状态\">\r\n          <el-select v-model=\"searchForm.status\" placeholder=\"选择状态\" clearable style=\"min-width: 120px;\">\r\n            <el-option label=\"待处理\" value=\"待处理\" />\r\n            <el-option label=\"已处理\" value=\"已处理\" />\r\n            <el-option label=\"已取消\" value=\"已取消\" />\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"日期\">\r\n          <el-date-picker\r\n            v-model=\"searchForm.date\"\r\n            type=\"date\"\r\n            placeholder=\"选择日期\"\r\n            clearable>\r\n          </el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\r\n          <el-button @click=\"resetSearch\">重置</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </el-card>\r\n\r\n    <!-- 预约列表 -->\r\n    <el-card class=\"table-card\">\r\n      <el-table\r\n        :data=\"reservations\"\r\n        v-loading=\"loading\"\r\n        style=\"width: 100%\">\r\n        \r\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\r\n        \r\n        <el-table-column prop=\"reader_name\" label=\"读者姓名\" width=\"120\" />\r\n        \r\n        <el-table-column prop=\"book_title\" label=\"图书名称\" />\r\n        \r\n        <el-table-column prop=\"date\" label=\"预约日期\" width=\"120\">\r\n          <template #default=\"scope\">\r\n            {{ formatDate(scope.row.date) }}\r\n          </template>\r\n        </el-table-column>\r\n        \r\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\r\n          <template #default=\"scope\">\r\n            <el-tag :type=\"getStatusType(scope.row.status)\">\r\n              {{ scope.row.status }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        \r\n        <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\r\n          <template #default=\"scope\">\r\n            <el-button\r\n              v-if=\"scope.row.status === '待处理'\"\r\n              size=\"small\"\r\n              type=\"success\"\r\n              @click=\"handleProcess(scope.row)\">\r\n              标记已处理\r\n            </el-button>\r\n            <el-button\r\n              size=\"small\"\r\n              type=\"danger\"\r\n              @click=\"handleDelete(scope.row)\">\r\n              删除\r\n            </el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n\r\n      <!-- 分页 -->\r\n      <div class=\"pagination\">\r\n        <el-pagination\r\n          v-model:current-page=\"currentPage\"\r\n          v-model:page-size=\"pageSize\"\r\n          :page-sizes=\"[10, 20, 50, 100]\"\r\n          :total=\"total\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handleCurrentChange\">\r\n        </el-pagination>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\nimport { ElMessage, ElMessageBox } from 'element-plus'\r\n\r\nexport default {\r\n  name: 'Reservation',\r\n  data() {\r\n    return {\r\n      reservations: [],\r\n      loading: false,\r\n      searchForm: {\r\n        status: '',\r\n        date: ''\r\n      },\r\n      currentPage: 1,\r\n      pageSize: 10,\r\n      total: 0\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadReservations()\r\n  },\r\n  methods: {\r\n    async loadReservations() {\r\n      this.loading = true\r\n      try {\r\n        const params = {\r\n          page: this.currentPage,\r\n          size: this.pageSize,\r\n          ...this.searchForm\r\n        }\r\n        \r\n        const response = await axios.get('http://localhost:8000/reservations', { params })\r\n        \r\n        if (response.data.success) {\r\n          this.reservations = response.data.data\r\n          this.total = response.data.total\r\n        } else {\r\n          ElMessage.error(response.data.message || '获取预约列表失败')\r\n        }\r\n      } catch (error) {\r\n        console.error('Load reservations error:', error)\r\n        ElMessage.error('获取预约列表失败')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    async handleProcess(row) {\r\n      try {\r\n        await ElMessageBox.confirm(\r\n          `确定要将预约 ${row.id} 标记为已处理吗？`,\r\n          '确认操作',\r\n          {\r\n            confirmButtonText: '确定',\r\n            cancelButtonText: '取消',\r\n            type: 'warning'\r\n          }\r\n        )\r\n\r\n        const response = await axios.put(`http://localhost:8000/reservations/${row.id}/process`)\r\n        \r\n        if (response.data.success) {\r\n          ElMessage.success('操作成功')\r\n          this.loadReservations()\r\n        } else {\r\n          ElMessage.error(response.data.message || '操作失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          console.error('Process reservation error:', error)\r\n          ElMessage.error('操作失败')\r\n        }\r\n      }\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await ElMessageBox.confirm(\r\n          `确定要删除预约 ${row.id} 吗？此操作不可恢复。`,\r\n          '确认删除',\r\n          {\r\n            confirmButtonText: '确定',\r\n            cancelButtonText: '取消',\r\n            type: 'warning'\r\n          }\r\n        )\r\n\r\n        const response = await axios.delete(`http://localhost:8000/reservations/${row.id}`)\r\n        \r\n        if (response.data.success) {\r\n          ElMessage.success('删除成功')\r\n          this.loadReservations()\r\n        } else {\r\n          ElMessage.error(response.data.message || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          console.error('Delete reservation error:', error)\r\n          ElMessage.error('删除失败')\r\n        }\r\n      }\r\n    },\r\n\r\n    handleSearch() {\r\n      this.currentPage = 1\r\n      this.loadReservations()\r\n    },\r\n\r\n    resetSearch() {\r\n      this.searchForm = {\r\n        status: '',\r\n        date: ''\r\n      }\r\n      this.currentPage = 1\r\n      this.loadReservations()\r\n    },\r\n\r\n    handleSizeChange(val) {\r\n      this.pageSize = val\r\n      this.loadReservations()\r\n    },\r\n\r\n    handleCurrentChange(val) {\r\n      this.currentPage = val\r\n      this.loadReservations()\r\n    },\r\n\r\n    refreshData() {\r\n      this.loadReservations()\r\n    },\r\n\r\n    formatDate(date) {\r\n      if (!date) return ''\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n\r\n    getStatusType(status) {\r\n      const statusMap = {\r\n        '待处理': 'warning',\r\n        '已处理': 'success',\r\n        '已取消': 'info'\r\n      }\r\n      return statusMap[status] || 'info'\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.reservation-page {\r\n  padding: 20px;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.page-header h2 {\r\n  margin: 0;\r\n  color: #303133;\r\n}\r\n\r\n.search-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-form {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n}\r\n\r\n.table-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.pagination {\r\n  display: flex;\r\n  justify-content: center;\r\n  margin-top: 20px;\r\n}\r\n\r\n.el-table {\r\n  margin-bottom: 20px;\r\n}\r\n</style> "]}]}