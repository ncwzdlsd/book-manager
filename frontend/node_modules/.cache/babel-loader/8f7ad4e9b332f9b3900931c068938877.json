ooltip />\r\n        \r\n        <el-table-column prop=\"comment_date\" label=\"建议日期\" width=\"120\">\r\n          <template #default=\"scope\">\r\n            {{ formatDate(scope.row.comment_date) }}\r\n          </template>\r\n        </el-table-column>\r\n        \r\n        <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\r\n          <template #default=\"scope\">\r\n            <el-button\r\n              size=\"small\"\r\n              type=\"info\"\r\n              @click=\"showDetailDialog(scope.row)\">\r\n              查看\r\n            </el-button>\r\n            <el-button\r\n              size=\"small\"\r\n              type=\"danger\"\r\n              @click=\"handleDelete(scope.row)\">\r\n              删除\r\n            </el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n\r\n      <!-- 分页 -->\r\n      <div class=\"pagination\">\r\n        <el-pagination\r\n          v-model:current-page=\"currentPage\"\r\n          v-model:page-size=\"pageSize\"\r\n          :page-sizes=\"[10, 20, 50, 100]\"\r\n          :total=\"total\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handleCurrentChange\">\r\n        </el-pagination>\r\n      </div>\r\n    </el-card>\r\n\r\n    <!-- 查看详情对话框 -->\r\n    <el-dialog\r\n      v-model=\"detailDialogVisible\"\r\n      title=\"建议详情\"\r\n      width=\"600px\">\r\n      \r\n      <div class=\"suggestion-detail\">\r\n        <div class=\"detail-item\">\r\n          <label>建议人：</label>\r\n          <span>{{ currentSuggestion.reader_name }}</span>\r\n        </div>\r\n        <div class=\"detail-item\">\r\n          <label>建议日期：</label>\r\n          <span>{{ formatDate(currentSuggestion.comment_date) }}</span>\r\n        </div>\r\n        <div class=\"detail-item\">\r\n          <label>建议内容：</label>\r\n          <div class=\"content-box\">{{ currentSuggestion.content }}</div>\r\n        </div>\r\n      </div>\r\n      \r\n      <template #footer>\r\n        <span class=\"dialog-footer\">\r\n          <el-button @click=\"detailDialogVisible = false\">关闭</el-button>\r\n        </span>\r\n      </template>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\nimport { ElMessage, ElMessageBox } from 'element-plus'\r\n\r\nexport default {\r\n  name: 'Suggestion',\r\n  data() {\r\n    return {\r\n      suggestions: [],\r\n      loading: false,\r\n      searchForm: {\r\n        content: '',\r\n        comment_date: ''\r\n      },\r\n      currentPage: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n      detailDialogVisible: false,\r\n      currentSuggestion: {}\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadSuggestions()\r\n  },\r\n  methods: {\r\n    async loadSuggestions() {\r\n      this.loading = true\r\n      try {\r\n        const params = {\r\n          page: this.currentPage,\r\n          size: this.pageSize,\r\n          ...this.searchForm\r\n        }\r\n        \r\n        const response = await axios.get('http://localhost:8000/suggestions', { params })\r\n        \r\n        if (response.data.success) {\r\n          this.suggestions = response.data.data\r\n          this.total = response.data.total\r\n        } else {\r\n          ElMessage.error(response.data.message || '获取建议列表失败')\r\n        }\r\n      } catch (error) {\r\n        console.error('Load suggestions error:', error)\r\n        ElMessage.error('获取建议列表失败')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    showDetailDialog(row) {\r\n      this.currentSuggestion = { ...row }\r\n      this.detailDialogVisible = true\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await ElMessageBox.confirm(\r\n          `确定要删除建议 ${row.id} 吗？此操作不可恢复。`,\r\n          '确认删除',\r\n          {\r\n            confirmButtonText: '确定',\r\n            cancelButtonText: '取消',\r\n            type: 'warning'\r\n          }\r\n        )\r\n\r\n        const response = await axios.delete(`http://localhost:8000/suggestions/${row.id}`)\r\n        \r\n        if (response.data.success) {\r\n          ElMessage.success('删除成功')\r\n          this.loadSuggestions()\r\n        } else {\r\n          ElMessage.error(response.data.message || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          console.error('Delete suggestion error:', error)\r\n          ElMessage.error('删除失败')\r\n        }\r\n      }\r\n    },\r\n\r\n    handleSearch() {\r\n      this.currentPage = 1\r\n      this.loadSuggestions()\r\n    },\r\n\r\n    resetSearch() {\r\n      this.searchForm = {\r\n        content: '',\r\n        comment_date: ''\r\n      }\r\n      this.currentPage = 1\r\n      this.loadSuggestions()\r\n    },\r\n\r\n    handleSizeChange(val) {\r\n      this.pageSize = val\r\n      this.loadSuggestions()\r\n    },\r\n\r\n    handleCurrentChange(val) {\r\n      this.currentPage = val\r\n      this.loadSuggestions()\r\n    },\r\n\r\n    refreshData() {\r\n      this.loadSuggestions()\r\n    },\r\n\r\n    formatDate(date) {\r\n      if (!date) return '-'\r\n      return new Date(date).toLocaleDateString()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.suggestion-page {\r\n  padding: 20px;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.page-header h2 {\r\n  margin: 0;\r\n  color: #303133;\r\n}\r\n\r\n.search-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-form {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n}\r\n\r\n.table-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.pagination {\r\n  display: flex;\r\n  justify-content: center;\r\n  margin-top: 20px;\r\n}\r\n\r\n.el-table {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.dialog-footer {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: 10px;\r\n}\r\n\r\n.suggestion-detail {\r\n  padding: 20px;\r\n}\r\n\r\n.detail-item {\r\n  margin-bottom: 15px;\r\n  display: flex;\r\n  align-items: flex-start;\r\n}\r\n\r\n.detail-item label {\r\n  font-weight: bold;\r\n  width: 100px;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.content-box {\r\n  background-color: #f5f5f5;\r\n  padding: 15px;\r\n  border-radius: 4px;\r\n  margin-top: 10px;\r\n  white-space: pre-wrap;\r\n  line-height: 1.6;\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAiB;;EACrBA,KAAK,EAAC;AAAa;;EAgEjBA,KAAK,EAAC;AAAY;;EAmBlBA,KAAK,EAAC;AAAmB;;EACvBA,KAAK,EAAC;AAAa;;EAInBA,KAAK,EAAC;AAAa;;EAInBA,KAAK,EAAC;AAAa;;EAEjBA,KAAK,EAAC;AAAa;;EAKpBA,KAAK,EAAC;AAAe;;;;;;;;;;;;;uBApGjCC,mBAAA,CAyGM,OAzGNC,UAyGM,GAxGJC,mBAAA,CAGM,OAHNC,UAGM,G,0BAFJD,mBAAA,CAAa,YAAT,MAAI,qBACRE,YAAA,CAA6DC,oBAAA;IAAlDC,IAAI,EAAC,SAAS;IAAEC,OAAK,EAAEC,QAAA,CAAAC;;sBAAa,MAAEC,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;oCAGnDC,mBAAA,WAAc,EACdP,YAAA,CAkBUQ,kBAAA;IAlBDb,KAAK,EAAC;EAAa;sBAC1B,MAgBU,CAhBVK,YAAA,CAgBUS,kBAAA;MAhBAC,MAAM,EAAE,IAAI;MAAGC,KAAK,EAAEC,KAAA,CAAAC,UAAU;MAAElB,KAAK,EAAC;;wBAChD,MAEe,CAFfK,YAAA,CAEec,uBAAA;QAFDC,KAAK,EAAC;MAAI;0BACtB,MAAyE,CAAzEf,YAAA,CAAyEgB,mBAAA;sBAAtDJ,KAAA,CAAAC,UAAU,CAACI,OAAO;qEAAlBL,KAAA,CAAAC,UAAU,CAACI,OAAO,GAAAC,MAAA;UAAEC,WAAW,EAAC,SAAS;UAACC,SAAS,EAAT;;;UAE/DpB,YAAA,CAOec,uBAAA;QAPDC,KAAK,EAAC;MAAM;0BACxB,MAKiB,CALjBf,YAAA,CAKiBqB,yBAAA;sBAJNT,KAAA,CAAAC,UAAU,CAACS,YAAY;qEAAvBV,KAAA,CAAAC,UAAU,CAACS,YAAY,GAAAJ,MAAA;UAChChB,IAAI,EAAC,MAAM;UACXiB,WAAW,EAAC,QAAQ;UACpBC,SAAS,EAAT;;;UAGJpB,YAAA,CAGec,uBAAA;0BAFb,MAA8D,CAA9Dd,YAAA,CAA8DC,oBAAA;UAAnDC,IAAI,EAAC,SAAS;UAAEC,OAAK,EAAEC,QAAA,CAAAmB;;4BAAc,MAAEjB,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;wCAClDN,YAAA,CAA8CC,oBAAA;UAAlCE,OAAK,EAAEC,QAAA,CAAAoB;QAAW;4BAAE,MAAElB,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;;;;;;;MAKxCC,mBAAA,UAAa,EACbP,YAAA,CAgDUQ,kBAAA;IAhDDb,KAAK,EAAC;EAAY;sBACzB,MAiCW,C,+BAjCX8B,YAAA,CAiCWC,mBAAA;MAhCRC,IAAI,EAAEf,KAAA,CAAAgB,WAAW;MAElBC,KAAmB,EAAnB;QAAA;MAAA;;wBAEA,MAAmD,CAAnD7B,YAAA,CAAmD8B,0BAAA;QAAlCC,IAAI,EAAC,IAAI;QA