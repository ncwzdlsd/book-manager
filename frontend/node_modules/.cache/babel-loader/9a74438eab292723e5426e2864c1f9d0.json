{"remainingRequest":"D:\\lyn\\cursorprj\\library-all\\frontend\\node_modules\\babel-loader\\lib\\index.js!D:\\lyn\\cursorprj\\library-all\\frontend\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\lyn\\cursorprj\\library-all\\frontend\\node_modules\\vue-loader-v16\\dist\\index.js??ref--1-1!D:\\lyn\\cursorprj\\library-all\\frontend\\src\\views\\staff\\Suggestion.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\lyn\\cursorprj\\library-all\\frontend\\src\\views\\staff\\Suggestion.vue","mtime":1752562057405},{"path":"D:\\lyn\\cursorprj\\library-all\\frontend\\babel.config.js","mtime":1752416817576},{"path":"D:\\lyn\\cursorprj\\library-all\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1752416669335},{"path":"D:\\lyn\\cursorprj\\library-all\\frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1752416671484},{"path":"D:\\lyn\\cursorprj\\library-all\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1752416669335},{"path":"D:\\lyn\\cursorprj\\library-all\\frontend\\node_modules\\vue-loader-v16\\dist\\index.js","mtime":1752416673274}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["axios","ElMessage","ElMessageBox","name","data","suggestions","loading","searchForm","content","comment_date","currentPage","pageSize","total","detailDialogVisible","currentSuggestion","mounted","loadSuggestions","methods","params","page","size","response","get","success","error","message","console","showDetailDialog","row","handleDelete","confirm","id","confirmButtonText","cancelButtonText","type","delete","handleSearch","resetSearch","handleSizeChange","val","handleCurrentChange","refreshData","formatDate","date","Date","toLocaleDateString"],"sources":["D:\\lyn\\cursorprj\\library-all\\frontend\\src\\views\\staff\\Suggestion.vue"],"sourcesContent":["<template>\n  <div class=\"suggestion-page\">\n    <div class=\"page-header\">\n      <h2>提案管理</h2>\n      <el-button type=\"primary\" @click=\"refreshData\">更新</el-button>\n    </div>\n\n    <!-- 検索とフィルター -->\n    <el-card class=\"search-card\">\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\n        <el-form-item label=\"内容\">\n          <el-input v-model=\"searchForm.content\" placeholder=\"提案内容を入力\" clearable />\n        </el-form-item>\n        <el-form-item label=\"提案日\">\n          <el-date-picker\n            v-model=\"searchForm.comment_date\"\n            type=\"date\"\n            value-format=\"YYYY-MM-DD\"\n            placeholder=\"提案日を選択\"\n            clearable>\n          </el-date-picker>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleSearch\">検索</el-button>\n          <el-button @click=\"resetSearch\">リセット</el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n\n    <!-- 提案リスト -->\n    <el-card class=\"table-card\">\n      <el-table\n        :data=\"suggestions\"\n        v-loading=\"loading\"\n        style=\"width: 100%\">\n        \n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\n        \n        <el-table-column prop=\"reader_name\" label=\"提案者\" width=\"120\" />\n        \n        <el-table-column prop=\"content\" label=\"提案内容\" show-overflow-tooltip />\n        \n        <el-table-column prop=\"comment_date\" label=\"提案日\" width=\"120\">\n          <template #default=\"scope\">\n            {{ formatDate(scope.row.comment_date) }}\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button\n              size=\"small\"\n              type=\"info\"\n              @click=\"showDetailDialog(scope.row)\">\n              詳細\n            </el-button>\n            <el-button\n              size=\"small\"\n              type=\"danger\"\n              @click=\"handleDelete(scope.row)\">\n              削除\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <!-- ページネーション -->\n      <div class=\"pagination\">\n        <el-pagination\n          v-model:current-page=\"currentPage\"\n          v-model:page-size=\"pageSize\"\n          :page-sizes=\"[10, 20, 50, 100]\"\n          :total=\"total\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\">\n        </el-pagination>\n      </div>\n    </el-card>\n\n    <!-- 詳細表示ダイアログ -->\n    <el-dialog\n      v-model=\"detailDialogVisible\"\n      title=\"提案詳細\"\n      width=\"600px\">\n      \n      <div class=\"suggestion-detail\">\n        <div class=\"detail-item\">\n          <label>提案者：</label>\n          <span>{{ currentSuggestion.reader_name }}</span>\n        </div>\n        <div class=\"detail-item\">\n          <label>提案日：</label>\n          <span>{{ formatDate(currentSuggestion.comment_date) }}</span>\n        </div>\n        <div class=\"detail-item\">\n          <label>提案内容：</label>\n          <div class=\"content-box\">{{ currentSuggestion.content }}</div>\n        </div>\n      </div>\n      \n      <template #footer>\n        <span class=\"dialog-footer\">\n          <el-button @click=\"detailDialogVisible = false\">閉じる</el-button>\n        </span>\n      </template>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nimport { ElMessage, ElMessageBox } from 'element-plus'\n\nexport default {\n  name: 'Suggestion',\n  data() {\n    return {\n      suggestions: [],\n      loading: false,\n      searchForm: {\n        content: '',\n        comment_date: ''\n      },\n      currentPage: 1,\n      pageSize: 10,\n      total: 0,\n      detailDialogVisible: false,\n      currentSuggestion: {}\n    }\n  },\n  mounted() {\n    this.loadSuggestions()\n  },\n  methods: {\n    async loadSuggestions() {\n      this.loading = true\n      try {\n        const params = {\n          page: this.currentPage,\n          size: this.pageSize,\n          ...this.searchForm\n        }\n        \n        const response = await axios.get('http://localhost:8000/suggestions', { params })\n        \n        if (response.data.success) {\n          this.suggestions = response.data.data\n          this.total = response.data.total\n        } else {\n          ElMessage.error(response.data.message || '提案リストの取得に失敗しました')\n        }\n      } catch (error) {\n        console.error('Load suggestions error:', error)\n        ElMessage.error('提案リストの取得に失敗しました')\n      } finally {\n        this.loading = false\n      }\n    },\n\n    showDetailDialog(row) {\n      this.currentSuggestion = { ...row }\n      this.detailDialogVisible = true\n    },\n\n    async handleDelete(row) {\n      try {\n        await ElMessageBox.confirm(\n          `提案 ${row.id} を削除しますか？この操作は元に戻せません。`,\n          '削除確認',\n          {\n            confirmButtonText: '確定',\n            cancelButtonText: 'キャンセル',\n            type: 'warning'\n          }\n        )\n\n        const response = await axios.delete(`http://localhost:8000/suggestions/${row.id}`)\n        \n        if (response.data.success) {\n          ElMessage.success('削除に成功しました')\n          this.loadSuggestions()\n        } else {\n          ElMessage.error(response.data.message || '削除に失敗しました')\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('Delete suggestion error:', error)\n          ElMessage.error('削除に失敗しました')\n        }\n      }\n    },\n\n    handleSearch() {\n      this.currentPage = 1\n      this.loadSuggestions()\n    },\n\n    resetSearch() {\n      this.searchForm = {\n        content: '',\n        comment_date: ''\n      }\n      this.currentPage = 1\n      this.loadSuggestions()\n    },\n\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadSuggestions()\n    },\n\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadSuggestions()\n    },\n\n    refreshData() {\n      this.loadSuggestions()\n    },\n\n    formatDate(date) {\n      if (!date) return '-'\n      return new Date(date).toLocaleDateString()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.suggestion-page {\n  padding: 20px;\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\n.page-header h2 {\n  margin: 0;\n  color: #303133;\n}\n\n.search-card {\n  margin-bottom: 20px;\n}\n\n.search-form {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n}\n\n.table-card {\n  margin-bottom: 20px;\n}\n\n.pagination {\n  display: flex;\n  justify-content: center;\n  margin-top: 20px;\n}\n\n.el-table {\n  margin-bottom: 20px;\n}\n\n.dialog-footer {\n  display: flex;\n  justify-content: flex-end;\n  gap: 10px;\n}\n\n.suggestion-detail {\n  padding: 20px;\n}\n\n.detail-item {\n  margin-bottom: 15px;\n  display: flex;\n  align-items: flex-start;\n}\n\n.detail-item label {\n  font-weight: bold;\n  width: 100px;\n  flex-shrink: 0;\n}\n\n.content-box {\n  background-color: #f5f5f5;\n  padding: 15px;\n  border-radius: 4px;\n  margin-top: 10px;\n  white-space: pre-wrap;\n  line-height: 1.6;\n}\n</style> "],"mappings":"AA+GA,OAAOA,KAAI,MAAO,OAAM;AACxB,SAASC,SAAS,EAAEC,YAAW,QAAS,cAAa;AAErD,eAAe;EACbC,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE,EAAE;MACfC,OAAO,EAAE,KAAK;MACdC,UAAU,EAAE;QACVC,OAAO,EAAE,EAAE;QACXC,YAAY,EAAE;MAChB,CAAC;MACDC,WAAW,EAAE,CAAC;MACdC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE,CAAC;MACRC,mBAAmB,EAAE,KAAK;MAC1BC,iBAAiB,EAAE,CAAC;IACtB;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,eAAe,CAAC;EACvB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,eAAeA,CAAA,EAAG;MACtB,IAAI,CAACV,OAAM,GAAI,IAAG;MAClB,IAAI;QACF,MAAMY,MAAK,GAAI;UACbC,IAAI,EAAE,IAAI,CAACT,WAAW;UACtBU,IAAI,EAAE,IAAI,CAACT,QAAQ;UACnB,GAAG,IAAI,CAACJ;QACV;QAEA,MAAMc,QAAO,GAAI,MAAMrB,KAAK,CAACsB,GAAG,CAAC,mCAAmC,EAAE;UAAEJ;QAAO,CAAC;QAEhF,IAAIG,QAAQ,CAACjB,IAAI,CAACmB,OAAO,EAAE;UACzB,IAAI,CAAClB,WAAU,GAAIgB,QAAQ,CA