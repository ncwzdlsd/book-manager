andleSearch() {\r\n      this.currentPage = 1\r\n      this.loadNotices()\r\n    },\r\n\r\n    resetSearch() {\r\n      this.searchForm = {\r\n        content: '',\r\n        send_date: ''\r\n      }\r\n      this.currentPage = 1\r\n      this.loadNotices()\r\n    },\r\n\r\n    handleSizeChange(val) {\r\n      this.pageSize = val\r\n      this.loadNotices()\r\n    },\r\n\r\n    handleCurrentChange(val) {\r\n      this.currentPage = val\r\n      this.loadNotices()\r\n    },\r\n\r\n    refreshData() {\r\n      this.loadNotices()\r\n    },\r\n\r\n    formatDate(date) {\r\n      if (!date) return ''\r\n      return new Date(date).toLocaleDateString() + ' ' + new Date(date).toLocaleTimeString()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.notice-page {\r\n  padding: 20px;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.page-header h2 {\r\n  margin: 0;\r\n  color: #303133;\r\n}\r\n\r\n.search-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-form {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n}\r\n\r\n.table-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.pagination {\r\n  display: flex;\r\n  justify-content: center;\r\n  margin-top: 20px;\r\n}\r\n\r\n.el-table {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.notice-content {\r\n  max-width: 300px;\r\n  display: inline-block;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  white-space: nowrap;\r\n}\r\n\r\n.notice-detail {\r\n  padding: 20px 0;\r\n}\r\n\r\n.detail-item {\r\n  margin-bottom: 20px;\r\n  display: flex;\r\n  align-items: flex-start;\r\n}\r\n\r\n.detail-item label {\r\n  font-weight: bold;\r\n  min-width: 80px;\r\n  color: #606266;\r\n}\r\n\r\n.detail-item span {\r\n  color: #303133;\r\n}\r\n\r\n.content-box {\r\n  background-color: #f5f7fa;\r\n  padding: 15px;\r\n  border-radius: 4px;\r\n  margin-top: 10px;\r\n  line-height: 1.6;\r\n  color: #303133;\r\n  white-space: pre-wrap;\r\n  word-break: break-word;\r\n}\r\n\r\n.dialog-footer {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAa;;EACjBA,KAAK,EAAC;AAAa;;EAyCVA,KAAK,EAAC;AAAgB;;EAyB7BA,KAAK,EAAC;AAAY;;EAkBlBA,KAAK,EAAC;AAAe;;EACnBA,KAAK,EAAC;AAAa;;EAInBA,KAAK,EAAC;AAAa;;EAInBA,KAAK,EAAC;AAAa;;EAInBA,KAAK,EAAC;AAAa;;EAEjBA,KAAK,EAAC;AAAa;;EAMpBA,KAAK,EAAC;AAAe;;;;;;;;;;;;;uBA1GjCC,mBAAA,CA+GM,OA/GNC,UA+GM,GA9GJC,mBAAA,CAGM,OAHNC,UAGM,G,0BAFJD,mBAAA,CAAa,YAAT,MAAI,qBACRE,YAAA,CAA6DC,oBAAA;IAAlDC,IAAI,EAAC,SAAS;IAAEC,OAAK,EAAEC,QAAA,CAAAC;;sBAAa,MAAEC,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;oCAGnDC,mBAAA,WAAc,EACdP,YAAA,CAsBUQ,kBAAA;IAtBDb,KAAK,EAAC;EAAa;sBAC1B,MAoBU,CApBVK,YAAA,CAoBUS,kBAAA;MApBAC,MAAM,EAAE,IAAI;MAAGC,KAAK,EAAEC,KAAA,CAAAC,UAAU;MAAElB,KAAK,EAAC;;wBAChD,MAMe,CANfK,YAAA,CAMec,uBAAA;QANDC,KAAK,EAAC;MAAM;0BACxB,MAIW,CAJXf,YAAA,CAIWgB,mBAAA;sBAHAJ,KAAA,CAAAC,UAAU,CAACI,OAAO;qEAAlBL,KAAA,CAAAC,UAAU,CAACI,OAAO,GAAAC,MAAA;UAC3BC,WAAW,EAAC,WAAW;UACvBC,SAAS,EAAT;;;UAGJpB,YAAA,CAOec,uBAAA;QAPDC,KAAK,EAAC;MAAM;0BACxB,MAKiB,CALjBf,YAAA,CAKiBqB,yBAAA;sBAJNT,KAAA,CAAAC,UAAU,CAACS,SAAS;qEAApBV,KAAA,CAAAC,UAAU,CAACS,SAAS,GAAAJ,MAAA;UAC7BhB,IAAI,EAAC,MAAM;UACXiB,WAAW,EAAC,QAAQ;UACpBC,SAAS,EAAT;;;UAGJpB,YAAA,CAGec,uBAAA;0BAFb,MAA8D,CAA9Dd,YAAA,CAA8DC,oBAAA;UAAnDC,IAAI,EAAC,SAAS;UAAEC,OAAK,EAAEC,QAAA,CAAAmB;;4BAAc,MAAEjB,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;wCAClDN,YAAA,CAA8CC,oBAAA;UAAlCE,OAAK,EAAEC,QAAA,CAAAoB;QAAW;4BAAE,MAAElB,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;;;;;;;MAKxCC,mBAAA,UAAa,EACbP,YAAA,CA8CUQ,kBAAA;IA9CDb,KAAK,EAAC;EAAY;sBACzB,MA+BW,C,+BA/BX8B,YAAA,CA+BWC,mBAAA;MA9BRC,IAAI,EAAEf,KAAA,CAAAgB,OAAO;MAEdC,KAAmB,EAAnB;QAAA;MAAA;;wBAEA,MAAmD,CAAnD7B,YAAA,CAAmD8B,0BAAA;QAAlCC,IAAI,EAAC,IAAI;QAAChB,KAAK,EAAC,IAAI;QAACiB,KAAK,EAAC;UAE5ChC,YAAA,CAIkB8B,0BAAA;QAJDC,IAAI,EAAC,SAAS;QAAChB,KAAK,EAAC,MAAM;QAAC,uBAAqB,EAArB;;QAChCkB,OAAO,EAAAC,QAAA,CAAEC,KAAK,KACvBrC,mBAAA,CAA2D,QAA3DsC,UAA2D,EAAAC,gBAAA,CAA3BF,KAAK,CAACG,GAAG,CAACrB,OAAO,iB;;UAI