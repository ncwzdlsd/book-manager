,"handleDelete","delete","handleSearch","resetSearch","handleSizeChange","val","handleCurrentChange","refreshData","formatDate","Date","toLocaleDateString","getStatusType","statusMap"],"sources":["D:\\lyn\\cursorprj\\library-all\\frontend\\src\\views\\staff\\Reservation.vue"],"sourcesContent":["<template>\n  <div class=\"reservation-page\">\n    <div class=\"page-header\">\n      <h2>予約管理</h2>\n      <el-button type=\"primary\" @click=\"refreshData\">更新</el-button>\n    </div>\n\n    <!-- 検索とフィルター -->\n    <el-card class=\"search-card\">\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\n        <el-form-item label=\"状態\">\n          <el-select v-model=\"searchForm.status\" placeholder=\"状態を選択\" clearable style=\"min-width: 120px;\">\n            <el-option label=\"処理待ち\" value=\"処理待ち\" />\n            <el-option label=\"処理済み\" value=\"処理済み\" />\n            <el-option label=\"キャンセル済み\" value=\"キャンセル済み\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"日付\">\n          <el-date-picker\n            v-model=\"searchForm.date\"\n            type=\"date\"\n            value-format=\"YYYY-MM-DD\"     \n            placeholder=\"日付を選択\"\n            clearable>\n          </el-date-picker>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleSearch\">検索</el-button>\n          <el-button @click=\"resetSearch\">リセット</el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n\n    <!-- 予約リスト -->\n    <el-card class=\"table-card\">\n      <el-table\n        :data=\"reservations\"\n        v-loading=\"loading\"\n        style=\"width: 100%\">\n        \n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\n        \n        <el-table-column prop=\"reader_name\" label=\"読者名\" width=\"120\" />\n        \n        <el-table-column prop=\"book_title\" label=\"図書名\" />\n        \n        <el-table-column prop=\"date\" label=\"予約日\" width=\"120\">\n          <template #default=\"scope\">\n            {{ formatDate(scope.row.date) }}\n          </template>\n        </el-table-column>\n        \n        <el-table-column prop=\"status\" label=\"状態\" width=\"100\">\n          <template #default=\"scope\">\n            <el-tag :type=\"getStatusType(scope.row.status)\">\n              {{ scope.row.status }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button\n              v-if=\"scope.row.status === '処理待ち'\"\n              size=\"small\"\n              type=\"success\"\n              @click=\"handleProcess(scope.row)\">\n              処理済みマーク\n            </el-button>\n            <el-button\n              size=\"small\"\n              type=\"danger\"\n              @click=\"handleDelete(scope.row)\">\n              削除\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <!-- ページネーション -->\n      <div class=\"pagination\">\n        <el-pagination\n          v-model:current-page=\"currentPage\"\n          v-model:page-size=\"pageSize\"\n          :page-sizes=\"[10, 20, 50, 100]\"\n          :total=\"total\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\">\n        </el-pagination>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nimport { ElMessage, ElMessageBox } from 'element-plus'\n\nexport default {\n  name: 'Reservation',\n  data() {\n    return {\n      reservations: [],\n      loading: false,\n      searchForm: {\n        status: '',\n        date: ''\n      },\n      currentPage: 1,\n      pageSize: 10,\n      total: 0\n    }\n  },\n  mounted() {\n    this.loadReservations()\n  },\n  methods: {\n    async loadReservations() {\n      this.loading = true\n      try {\n        const params = {\n          page: this.currentPage,\n          size: this.pageSize,\n          ...this.searchForm\n        }\n        \n        const response = await axios.get('http://localhost:8000/reservations', { params })\n        \n        if (response.data.success) {\n          this.reservations = response.data.data\n          this.total = response.data.total\n        } else {\n          ElMessage.error(response.data.message || '予約リストの取得に失敗しました')\n        }\n      } catch (error) {\n        console.error('Load reservations error:', error)\n        ElMessage.error('予約リストの取得に失敗しました')\n      } finally {\n        this.loading = false\n      }\n    },\n\n    async handleProcess(row) {\n      try {\n        await ElMessageBox.confirm(\n          `予約 ${row.id} を処理済みとしてマークしますか？`,\n          '操作確認',\n          {\n            confirmButtonText: '確定',\n            cancelButtonText: 'キャンセル',\n            type: 'warning'\n          }\n        )\n\n        const response = await axios.put(`http://localhost:8000/reservations/${row.id}/process`)\n        \n        if (response.data.success) {\n          ElMessage.success('操作に成功しました')\n          this.loadReservations()\n        } else {\n          ElMessage.error(response.data.message || '操作に失敗しました')\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('Process reservation error:', error)\n          ElMessage.error('操作に失敗しました')\n        }\n      }\n    },\n\n    async handleDelete(row) {\n      try {\n        await ElMessageBox.confirm(\n          `予約 ${row.id} を削除しますか？この操作は元に戻せません。`,\n          '削除確認',\n          {\n            confirmButtonText: '確定',\n            cancelButtonText: 'キャンセル',\n            type: 'warning'\n          }\n        )\n\n        const response = await axios.delete(`http://localhost:8000/reservations/${row.id}`)\n        \n        if (response.data.success) {\n          ElMessage.success('削除に成功しました')\n          this.loadReservations()\n        } else {\n          ElMessage.error(response.data.message || '削除に失敗しました')\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('Delete reservation error:', error)\n          ElMessage.error('削除に失敗しました')\n        }\n      }\n    },\n\n    handleSearch() {\n      this.currentPage = 1\n      this.loadReservations()\n    },\n\n    resetSearch() {\n      this.searchForm = {\n        status: '',\n        date: ''\n      }\n      this.currentPage = 1\n      this.loadReservations()\n    },\n\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadReservations()\n    },\n\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadReservations()\n    },\n\n    refreshData() {\n      this.loadReservations()\n    },\n\n    formatDate(date) {\n      if (!date) return ''\n      return new Date(date).toLocaleDateString()\n    },\n\n    getStatusType(status) {\n      const statusMap = {\n        '処理待ち': 'warning',\n        '処理済み': 'success',\n        'キャンセル済み': 'info'\n      }\n      return statusMap[status] || 'info'\n    }\n  }\n}\n</script>\n\n<style scoped>\n.reservation-page {\n  padding: 20px;\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\n.page-header h2 {\n  margin: 0;\n  color: #303133;\n}\n\n.search-card {\n  margin-bottom: 20px;\n}\n\n.search-form {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n}\n\n.table-card {\n  margin-bottom: 20px;\n}\n\n.pagination {\n  display: flex;\n  justify-content: center;\n  margin-top: 20px;\n}\n\n.el-table {\n  margin-bottom: 20px;\n}\n</style> "],"mappings":"AAgGA,OAAOA,KAAI,MAAO,OAAM;AACxB,SAASC,SAAS,EAAEC,YAAW,QAAS,cAAa;AAErD,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE,EAAE;MAChBC,OAAO,EAAE,KAAK;MACdC,UAAU,EAAE;QACVC,MAAM,EAAE,EAAE;QACVC,IAAI,EAAE;MACR,CAAC;MACDC,WAAW,EAAE,CAAC;MACdC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE;IACT;EAC