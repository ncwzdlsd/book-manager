button type=\"primary\" @click=\"refreshData\">刷新</el-button>\r\n    </div>\r\n\r\n    <!-- 搜索和筛选 -->\r\n    <el-card class=\"search-card\">\r\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\r\n        <el-form-item label=\"状态\">\r\n          <el-select v-model=\"searchForm.status\" placeholder=\"选择状态\" clearable style=\"min-width: 120px;\">\r\n            <el-option label=\"待处理\" value=\"待处理\" />\r\n            <el-option label=\"已处理\" value=\"已处理\" />\r\n            <el-option label=\"已取消\" value=\"已取消\" />\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"日期\">\r\n          <el-date-picker\r\n            v-model=\"searchForm.date\"\r\n            type=\"date\"\r\n            placeholder=\"选择日期\"\r\n            clearable>\r\n          </el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\r\n          <el-button @click=\"resetSearch\">重置</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </el-card>\r\n\r\n    <!-- 预约列表 -->\r\n    <el-card class=\"table-card\">\r\n      <el-table\r\n        :data=\"reservations\"\r\n        v-loading=\"loading\"\r\n        style=\"width: 100%\">\r\n        \r\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\r\n        \r\n        <el-table-column prop=\"book_title\" label=\"图书名称\" />\r\n        \r\n        <el-table-column prop=\"date\" label=\"预约日期\" width=\"120\">\r\n          <template #default=\"scope\">\r\n            {{ formatDate(scope.row.date) }}\r\n          </template>\r\n        </el-table-column>\r\n        \r\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\r\n          <template #default=\"scope\">\r\n            <el-tag :type=\"getStatusType(scope.row.status)\">\r\n              {{ scope.row.status }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        \r\n        <el-table-column label=\"操作\" width=\"120\" fixed=\"right\">\r\n          <template #default=\"scope\">\r\n            <el-button\r\n              v-if=\"scope.row.status === '待处理'\"\r\n              size=\"small\"\r\n              type=\"danger\"\r\n              @click=\"handleDelete(scope.row)\">\r\n              取消预约\r\n            </el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n\r\n      <!-- 分页 -->\r\n      <div class=\"pagination\">\r\n        <el-pagination\r\n          v-model:current-page=\"currentPage\"\r\n          v-model:page-size=\"pageSize\"\r\n          :page-sizes=\"[10, 20, 50, 100]\"\r\n          :total=\"total\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handleCurrentChange\">\r\n        </el-pagination>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\nimport { ElMessage, ElMessageBox } from 'element-plus'\r\n\r\nexport default {\r\n  name: 'ReaderReservation',\r\n  data() {\r\n    return {\r\n      reservations: [],\r\n      loading: false,\r\n      searchForm: {\r\n        status: '',\r\n        date: ''\r\n      },\r\n      currentPage: 1,\r\n      pageSize: 10,\r\n      total: 0\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadReservations()\r\n  },\r\n  methods: {\r\n    async loadReservations() {\r\n      this.loading = true\r\n      try {\r\n        const userInfo = JSON.parse(localStorage.getItem('userInfo'))\r\n        const params = {\r\n          page: this.currentPage,\r\n          size: this.pageSize,\r\n          reader_id: userInfo.id,\r\n          ...this.searchForm\r\n        }\r\n        \r\n        const response = await axios.get('http://localhost:8000/reader/reservations', { params })\r\n        \r\n        if (response.data.success) {\r\n          this.reservations = response.data.data\r\n          this.total = response.data.total\r\n        } else {\r\n          ElMessage.error(response.data.message || '获取预约列表失败')\r\n        }\r\n      } catch (error) {\r\n        console.error('Load reservations error:', error)\r\n        ElMessage.error('获取预约列表失败')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await ElMessageBox.confirm(\r\n          `确定要取消预约《${row.book_title}》吗？`,\r\n          '确认取消',\r\n          {\r\n            confirmButtonText: '确定',\r\n            cancelButtonText: '取消',\r\n            type: 'warning'\r\n          }\r\n        )\r\n\r\n        const response = await axios.delete(`http://localhost:8000/reader/reservations/${row.id}`)\r\n        \r\n        if (response.data.success) {\r\n          ElMessage.success('预约取消成功')\r\n          this.loadReservations()\r\n        } else {\r\n          ElMessage.error(response.data.message || '取消失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          console.error('Delete reservation error:', error)\r\n          ElMessage.error('取消失败')\r\n        }\r\n      }\r\n    },\r\n\r\n    handleSearch() {\r\n      this.currentPage = 1\r\n      this.loadReservations()\r\n    },\r\n\r\n    resetSearch() {\r\n      this.searchForm = {\r\n        status: '',\r\n        date: ''\r\n      }\r\n      this.currentPage = 1\r\n      this.loadReservations()\r\n    },\r\n\r\n    handleSizeChange(val) {\r\n      this.pageSize = val\r\n      this.loadReservations()\r\n    },\r\n\r\n    handleCurrentChange(val) {\r\n      this.currentPage = val\r\n      this.loadReservations()\r\n    },\r\n\r\n    refreshData() {\r\n      this.loadReservations()\r\n    },\r\n\r\n    formatDate(date) {\r\n      if (!date) return ''\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n\r\n    getStatusType(status) {\r\n      const statusMap = {\r\n        '待处理': 'warning',\r\n        '已处理': 'success',\r\n        '已取消': 'info'\r\n      }\r\n      return statusMap[status] || 'info'\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.reservation-page {\r\n  padding: 20px;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.page-header h2 {\r\n  margin: 0;\r\n  color: #303133;\r\n}\r\n\r\n.search-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-form {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n}\r\n\r\n.table-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.pagination {\r\n  display: flex;\r\n  justify-content: center;\r\n  margin-top: 20px;\r\n}\r\n\r\n.el-table {\r\n  margin-bottom: 20px;\r\n}\r\n</style> "],"mappings":"AAuFA,OAAOA,KAAI,MAAO,OAAM;AACxB,SAASC,SAAS,EAAEC,YAAW,QAAS,cAAa;AAErD,eAAe;EACbC,IAAI,EAAE,mBAAmB;EACzBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE,EAAE;MAChBC,OAAO,EAAE,KAAK;MACdC,UAAU,EAAE;QACVC,MAAM,EAAE,EAAE;QACVC,IAAI,EAAE;MACR,CAAC;MACDC,WAAW,EAAE,CAAC;MACdC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE;IACT;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,gBAAgB,CAAC;EACxB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,gBAAgBA,CAAA,EAAG;MACvB,IAAI,CAACR,OAAM,GAAI,IAAG;MAClB,IAAI;QACF,MAAMU,QAAO,GAAIC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,UAAU,CAAC;QAC5D,MAAMC,MAAK,GAAI;UACbC,IAAI,EAAE,IAAI,CAACZ,WAAW;UACtBa,IAAI,EAAE,IAAI,CAACZ,QAAQ;UACnBa,SAAS,EAAER,QAAQ,CAACS,EAAE;UACtB,GAAG,IAAI,CAAClB;QACV;QAEA,MAAMmB,QAAO,GAAI,MAAM1B,KAAK,CAAC2B,GAAG,CAAC,2CAA2C,EAAE;UAAEN;QAAO,CAAC;QAExF,IAAIK,QAAQ,CAACtB,IAAI,CAACwB,OAAO,EAAE;UACzB,IAAI,CAACvB,YAAW,GAAIqB,QAAQ,CAACtB,IAAI,CAACA,IAAG;UACrC,IAAI,CAACQ,KAAI,GAAIc,QAAQ,CAACtB,IAAI,CAACQ,KAAI;QACjC,OAAO;UACLX,SAAS,CAAC4B,KAAK,CAACH,QAAQ,CAACtB,IAAI,CAAC0B,OAAM,IAAK,UAAU;QACrD;MACF,EAAE,OAAOD,KAAK,EAAE;QACdE,OAAO,CAACF,KAAK,CAAC,0BAA0B,EAAEA,KAAK;QAC/C5B,SAAS,CAAC4B,KAAK,CAAC,UAAU;MAC5B,UAAU;QACR,IAAI,CAACvB,OAAM,GAAI,KAAI;MACrB;IACF,CAAC;IAED,MAAM0B,YAAYA,CAACC,GAAG,EAAE;MACtB,IAAI;QACF,MAAM/B,YAAY,CAACgC,OAAO,CACxB,WAAWD,GAAG,CAACE,UAAU,KAAK,