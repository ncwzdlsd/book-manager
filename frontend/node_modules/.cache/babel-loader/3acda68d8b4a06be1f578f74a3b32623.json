  \r\n        <el-table-column prop=\"book_title\" label=\"图书名称\" />\r\n        \r\n        <el-table-column prop=\"date\" label=\"预约日期\" width=\"120\">\r\n          <template #default=\"scope\">\r\n            {{ formatDate(scope.row.date) }}\r\n          </template>\r\n        </el-table-column>\r\n        \r\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\r\n          <template #default=\"scope\">\r\n            <el-tag :type=\"getStatusType(scope.row.status)\">\r\n              {{ scope.row.status }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        \r\n        <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\r\n          <template #default=\"scope\">\r\n            <el-button\r\n              v-if=\"scope.row.status === '待处理'\"\r\n              size=\"small\"\r\n              type=\"success\"\r\n              @click=\"handleProcess(scope.row)\">\r\n              标记已处理\r\n            </el-button>\r\n            <el-button\r\n              size=\"small\"\r\n              type=\"danger\"\r\n              @click=\"handleDelete(scope.row)\">\r\n              删除\r\n            </el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n\r\n      <!-- 分页 -->\r\n      <div class=\"pagination\">\r\n        <el-pagination\r\n          v-model:current-page=\"currentPage\"\r\n          v-model:page-size=\"pageSize\"\r\n          :page-sizes=\"[10, 20, 50, 100]\"\r\n          :total=\"total\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handleCurrentChange\">\r\n        </el-pagination>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\nimport { ElMessage, ElMessageBox } from 'element-plus'\r\n\r\nexport default {\r\n  name: 'Reservation',\r\n  data() {\r\n    return {\r\n      reservations: [],\r\n      loading: false,\r\n      searchForm: {\r\n        status: '',\r\n        date: ''\r\n      },\r\n      currentPage: 1,\r\n      pageSize: 10,\r\n      total: 0\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadReservations()\r\n  },\r\n  methods: {\r\n    async loadReservations() {\r\n      this.loading = true\r\n      try {\r\n        const params = {\r\n          page: this.currentPage,\r\n          size: this.pageSize,\r\n          ...this.searchForm\r\n        }\r\n        \r\n        const response = await axios.get('http://localhost:8000/reservations', { params })\r\n        \r\n        if (response.data.success) {\r\n          this.reservations = response.data.data\r\n          this.total = response.data.total\r\n        } else {\r\n          ElMessage.error(response.data.message || '获取预约列表失败')\r\n        }\r\n      } catch (error) {\r\n        console.error('Load reservations error:', error)\r\n        ElMessage.error('获取预约列表失败')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    async handleProcess(row) {\r\n      try {\r\n        await ElMessageBox.confirm(\r\n          `确定要将预约 ${row.id} 标记为已处理吗？`,\r\n          '确认操作',\r\n          {\r\n            confirmButtonText: '确定',\r\n            cancelButtonText: '取消',\r\n            type: 'warning'\r\n          }\r\n        )\r\n\r\n        const response = await axios.put(`http://localhost:8000/reservations/${row.id}/process`)\r\n        \r\n        if (response.data.success) {\r\n          ElMessage.success('操作成功')\r\n          this.loadReservations()\r\n        } else {\r\n          ElMessage.error(response.data.message || '操作失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          console.error('Process reservation error:', error)\r\n          ElMessage.error('操作失败')\r\n        }\r\n      }\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await ElMessageBox.confirm(\r\n          `确定要删除预约 ${row.id} 吗？此操作不可恢复。`,\r\n          '确认删除',\r\n          {\r\n            confirmButtonText: '确定',\r\n            cancelButtonText: '取消',\r\n            type: 'warning'\r\n          }\r\n        )\r\n\r\n        const response = await axios.delete(`http://localhost:8000/reservations/${row.id}`)\r\n        \r\n        if (response.data.success) {\r\n          ElMessage.success('删除成功')\r\n          this.loadReservations()\r\n        } else {\r\n          ElMessage.error(response.data.message || '删除失败')\r\n        }\r\n      } catch (error) {\r\n        if (error !== 'cancel') {\r\n          console.error('Delete reservation error:', error)\r\n          ElMessage.error('删除失败')\r\n        }\r\n      }\r\n    },\r\n\r\n    handleSearch() {\r\n      this.currentPage = 1\r\n      this.loadReservations()\r\n    },\r\n\r\n    resetSearch() {\r\n      this.searchForm = {\r\n        status: '',\r\n        date: ''\r\n      }\r\n      this.currentPage = 1\r\n      this.loadReservations()\r\n    },\r\n\r\n    handleSizeChange(val) {\r\n      this.pageSize = val\r\n      this.loadReservations()\r\n    },\r\n\r\n    handleCurrentChange(val) {\r\n      this.currentPage = val\r\n      this.loadReservations()\r\n    },\r\n\r\n    refreshData() {\r\n      this.loadReservations()\r\n    },\r\n\r\n    formatDate(date) {\r\n      if (!date) return ''\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n\r\n    getStatusType(status) {\r\n      const statusMap = {\r\n        '待处理': 'warning',\r\n        '已处理': 'success',\r\n        '已取消': 'info'\r\n      }\r\n      return statusMap[status] || 'info'\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.reservation-page {\r\n  padding: 20px;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.page-header h2 {\r\n  margin: 0;\r\n  color: #303133;\r\n}\r\n\r\n.search-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-form {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n}\r\n\r\n.table-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.pagination {\r\n  display: flex;\r\n  justify-content: center;\r\n  margin-top: 20px;\r\n}\r\n\r\n.el-table {\r\n  margin-bottom: 20px;\r\n}\r\n</style> "],"mappings":";;EACOA,KAAK,EAAC;AAAkB;;EACtBA,KAAK,EAAC;AAAa;;EA6EjBA,KAAK,EAAC;AAAY;;;;;;;;;;;;;;uBA9E3BC,mBAAA,CA0FM,OA1FNC,UA0FM,GAzFJC,mBAAA,CAGM,OAHNC,UAGM,G,0BAFJD,mBAAA,CAAa,YAAT,MAAI,qBACRE,YAAA,CAA6DC,oBAAA;IAAlDC,IAAI,EAAC,SAAS;IAAEC,OAAK,EAAEC,QAAA,CAAAC;;sBAAa,MAAEC,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;oCAGnDC,mBAAA,WAAc,EACdP,YAAA,CAsBUQ,kBAAA;IAtBDb,KAAK,EAAC;EAAa;sBAC1B,MAoBU,CApBVK,YAAA,CAoBUS,kBAAA;MApBAC,MAAM,EAAE,IAAI;MAAGC,KAAK,EAAEC,KAAA,CAAAC,UAAU;MAAElB,KAAK,EAAC;;wBAChD,MAMe,CANfK,YAAA,CAMec,uBAAA;QANDC,KAAK,EAAC;MAAI;0BACtB,MAIY,CAJZf,YAAA,CAIYgB,oBAAA;sBAJQJ,KAAA,CAAAC,UAAU,CAACI,MAAM;qEAAjBL,KAAA,CAAAC,UAAU,CAACI,MAAM,GAAAC,MAAA;UAAEC,WAAW,EAAC,MAAM;UAACC,SAAS,EAAT,EAAS;UAACC,KAAyB,EAAzB;YAAA;UAAA;;4BAClE,MAAqC,CAArCrB,YAAA,CAAqCsB,oBAAA;YAA1BP,KAAK,EAAC,KAAK;YAACQ,KAAK,EAAC;cAC7BvB,YAAA,CAAqCsB,oBAAA;YAA1BP,KAAK,EAAC,KAAK;YAACQ,KAAK,EAAC;cAC7BvB,YAAA,CAAqCsB,oBAAA;YAA1BP,KAAK,EAAC,KAAK;YAACQ,KAAK,EAAC;;;;;UAGjCvB,YAAA,CAOec,uBAAA;QAPDC,KAAK,EAAC;MAAI;0BACtB,MAKiB,CALjBf,YAAA,CAKiBwB,yBAAA;sBAJNZ,KAAA,CAAAC,UAAU,CAACY,IAAI;qEAAfb,KAAA,CAAAC,UAAU,CAACY,IAAI,GAAAP,MAAA;UACxBhB,IAAI,EAAC,MAAM;UACXiB,WAAW,EAAC,MAAM;UAClBC,SAAS,EAAT;;;UAGJpB,YAAA,CAGec,uBAAA;0BAFb,MAA8D,CAA9Dd,YAAA,CAA8DC,oBAAA;UAAnDC,IAAI,EAAC,SAAS;UAAEC,OAAK,EAAEC,QAAA,CAAAsB;;4BAAc,MAAEpB,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;wCAClDN,YAAA,CAA8CC,oBAAA;UAAlCE,OAAK,EAAEC,QAAA,CAAAuB;QAAW;4BAAE,MAAErB,MAAA,QAAAA,MAAA,O,iBAAF,IAAE,E;;;;;;;;;MAKxCC,mBAAA,UAAa,EACbP,YAAA,CAyDUQ,kBAAA;IAzDDb,KAAK,EAAC;EAAY;sBACzB,MA0CW,C,+BA1CXiC,YAAA,CA0CWC,mBAAA;MAzCRC,IAAI,EAAElB,KAAA,CAAAmB,YAAY;MAEnBV,KAAmB,EAAnB;QAAA;MAAA;;wBAEA,MAAmD,CAAnDrB,YAAA,CAAmDgC,0BAAA;QAAlCC,IAAI,EAAC,IAAI;QAAClB,KAAK,EAAC,IAAI;QAACmB,KAAK,EAAC;UAE5ClC,YAAA,CAA+DgC,0BAAA;QAA9CC,IAAI,EAAC,aA