on>\n    </div>\n\n    <!-- 検索とフィルター -->\n    <el-card class=\"search-card\">\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\n        <el-form-item label=\"状態\">\n          <el-select v-model=\"searchForm.status\" placeholder=\"状態を選択\" clearable style=\"min-width: 120px;\">\n            <el-option label=\"貸出中\" value=\"貸出中\" />\n            <el-option label=\"返却済み\" value=\"返却済み\" />\n            <el-option label=\"延滞\" value=\"延滞\" />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"貸出日\">\n          <el-date-picker\n            v-model=\"searchForm.lend_date\"\n            type=\"date\"\n            value-format=\"YYYY-MM-DD\"     \n            placeholder=\"貸出日を選択\"\n            clearable>\n          </el-date-picker>\n        </el-form-item>\n        <el-form-item label=\"返却予定日\">\n          <el-date-picker\n            v-model=\"searchForm.due_date\"\n            type=\"date\"\n            value-format=\"YYYY-MM-DD\"     \n            placeholder=\"返却予定日を選択\"\n            clearable>\n          </el-date-picker>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" @click=\"handleSearch\">検索</el-button>\n          <el-button @click=\"resetSearch\">リセット</el-button>\n        </el-form-item>\n      </el-form>\n    </el-card>\n\n    <!-- 貸出リスト -->\n    <el-card class=\"table-card\">\n      <el-table\n        :data=\"borrows\"\n        v-loading=\"loading\"\n        style=\"width: 100%\">\n        \n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\" />\n        \n        <el-table-column prop=\"reader_name\" label=\"読者名\" width=\"120\" />\n        \n        <el-table-column prop=\"book_title\" label=\"図書名\" />\n        \n        <el-table-column prop=\"lend_date\" label=\"貸出日\" width=\"120\">\n          <template #default=\"scope\">\n            {{ formatDate(scope.row.lend_date) }}\n          </template>\n        </el-table-column>\n        \n        <el-table-column prop=\"due_date\" label=\"返却予定日\" width=\"120\">\n          <template #default=\"scope\">\n            {{ formatDate(scope.row.due_date) }}\n          </template>\n        </el-table-column>\n        \n        <el-table-column prop=\"return_date\" label=\"返却日\" width=\"120\">\n          <template #default=\"scope\">\n            {{ formatDate(scope.row.return_date) }}\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"状態\" width=\"100\">\n          <template #default=\"scope\">\n            <el-tag :type=\"getStatusType(scope.row)\">\n              {{ getStatusText(scope.row) }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        \n        <el-table-column label=\"操作\" width=\"120\" fixed=\"right\">\n          <template #default=\"scope\">\n            <el-button\n              size=\"small\"\n              type=\"danger\"\n              @click=\"handleDelete(scope.row)\">\n              削除\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n\n      <!-- ページネーション -->\n      <div class=\"pagination\">\n        <el-pagination\n          v-model:current-page=\"currentPage\"\n          v-model:page-size=\"pageSize\"\n          :page-sizes=\"[10, 20, 50, 100]\"\n          :total=\"total\"\n          layout=\"total, sizes, prev, pager, next, jumper\"\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\">\n        </el-pagination>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nimport { ElMessage, ElMessageBox } from 'element-plus'\n\nexport default {\n  name: 'Borrow',\n  data() {\n    return {\n      borrows: [],\n      loading: false,\n      searchForm: {\n        status: '',\n        lend_date: '',\n        due_date: ''\n      },\n      currentPage: 1,\n      pageSize: 10,\n      total: 0\n    }\n  },\n  mounted() {\n    this.loadBorrows()\n  },\n  methods: {\n    async loadBorrows() {\n      this.loading = true\n      try {\n        const params = {\n          page: this.currentPage,\n          size: this.pageSize,\n          ...this.searchForm\n        }\n        \n        const response = await axios.get('http://localhost:8000/borrows', { params })\n        \n        if (response.data.success) {\n          this.borrows = response.data.data\n          this.total = response.data.total\n        } else {\n          ElMessage.error(response.data.message || '貸出リストの取得に失敗しました')\n        }\n      } catch (error) {\n        console.error('Load borrows error:', error)\n        ElMessage.error('貸出リストの取得に失敗しました')\n      } finally {\n        this.loading = false\n      }\n    },\n\n    async handleDelete(row) {\n      try {\n        await ElMessageBox.confirm(\n          `貸出記録 ${row.id} を削除しますか？この操作は元に戻せません。`,\n          '削除確認',\n          {\n            confirmButtonText: '確定',\n            cancelButtonText: 'キャンセル',\n            type: 'warning'\n          }\n        )\n\n        const response = await axios.delete(`http://localhost:8000/borrows/${row.id}`)\n        \n        if (response.data.success) {\n          ElMessage.success('削除に成功しました')\n          this.loadBorrows()\n        } else {\n          ElMessage.error(response.data.message || '削除に失敗しました')\n        }\n      } catch (error) {\n        if (error !== 'cancel') {\n          console.error('Delete borrow error:', error)\n          ElMessage.error('削除に失敗しました')\n        }\n      }\n    },\n\n    handleSearch() {\n      this.currentPage = 1\n      this.loadBorrows()\n    },\n\n    resetSearch() {\n      this.searchForm = {\n        status: '',\n        lend_date: '',\n        due_date: ''\n      }\n      this.currentPage = 1\n      this.loadBorrows()\n    },\n\n    handleSizeChange(val) {\n      this.pageSize = val\n      this.loadBorrows()\n    },\n\n    handleCurrentChange(val) {\n      this.currentPage = val\n      this.loadBorrows()\n    },\n\n    refreshData() {\n      this.loadBorrows()\n    },\n\n    formatDate(date) {\n      if (!date) return '-'\n      return new Date(date).toLocaleDateString()\n    },\n\n    getStatusText(row) {\n      if (row.return_date) {\n        return '返却済み'\n      }\n      const today = new Date()\n      const dueDate = new Date(row.due_date)\n      if (today > dueDate) {\n        return '延滞'\n      }\n      return '貸出中'\n    },\n\n    getStatusType(row) {\n      if (row.return_date) {\n        return 'success'\n      }\n      const today = new Date()\n      const dueDate = new Date(row.due_date)\n      if (today > dueDate) {\n        return 'danger'\n      }\n      return 'warning'\n    }\n  }\n}\n</script>\n\n<style scoped>\n.borrow-page {\n  padding: 20px;\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\n.page-header h2 {\n  margin: 0;\n  color: #303133;\n}\n\n.search-card {\n  margin-bottom: 20px;\n}\n\n.search-form {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n}\n\n.table-card {\n  margin-bottom: 20px;\n}\n\n.pagination {\n  display: flex;\n  justify-content: center;\n  margin-top: 20px;\n}\n\n.el-table {\n  margin-bottom: 20px;\n}\n</style> "],"mappings":"AA8GA,OAAOA,KAAI,MAAO,OAAM;AACxB,SAASC,SAAS,EAAEC,YAAW,QAAS,cAAa;AAErD,eAAe;EACbC,IAAI,EAAE,QAAQ;EACdC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,EAAE;MACXC,OAAO,EAAE,KAAK;MACdC,UAAU,EAAE;QACVC,MAAM,EAAE,EAAE;QACVC,SAAS,EAAE,EAAE;QACbC,QAAQ,EAAE;MACZ,CAAC;MACDC,WAAW,EAAE,CAAC;MACdC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE;IACT;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,WAAW,CAAC;EACnB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,WAAWA,CAAA,EAAG;MAClB,IAAI,CAACT,OAAM,GAAI,IAAG;MAClB,IAAI;QACF,MAAMW,MAAK,GAAI;UACbC,IAAI,EAAE,IAAI,CAACP,WAAW;UACtBQ,IAAI,EAAE,IAAI,CAACP,QAAQ;UACnB,GAAG,IAAI,CAACL;QACV;QAEA,MAAMa,QAAO,GAAI,MAAMpB,KAAK,CAACqB,GAAG,CAAC,+BAA+B,EAAE;UAAEJ;QAAO,CAAC;QAE5E,IAAIG,QAAQ,CAAChB,IAAI,CAACkB,OAAO,EAAE;UACzB,IAAI,CAACjB,OAAM,GAAIe,QAAQ,CAAChB,IAAI,CAACA