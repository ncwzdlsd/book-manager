Info')\r\n  \r\n  if (to.meta.requiresAuth) {\r\n    if (!userInfo) {\r\n      next('/login')\r\n    } else {\r\n      const user = JSON.parse(userInfo)\r\n      if (to.meta.role && to.meta.role !== user.role) {\r\n        next('/login')\r\n      } else {\r\n        next()\r\n      }\r\n    }\r\n  } else {\r\n    next()\r\n  }\r\n})\r\n\r\nexport default router "],"mappings":"AAAA,SAASA,YAAY,EAAEC,gBAAgB,QAAQ,YAAY;AAC3D,OAAOC,KAAK,MAAM,oBAAoB;AACtC,OAAOC,SAAS,MAAM,yBAAyB;AAC/C,OAAOC,WAAW,MAAM,gCAAgC;AACxD,OAAOC,UAAU,MAAM,0BAA0B;AACjD,OAAOC,iBAAiB,MAAM,iCAAiC;AAE/D,MAAMC,MAAM,GAAG,CACb;EACEC,IAAI,EAAE,GAAG;EACTC,IAAI,EAAE,MAAM;EACZC,QAAQ,EAAE,QAAQ,CAAE;AACtB,CAAC,EACD;EACEF,IAAI,EAAE,QAAQ;EACdC,IAAI,EAAE,OAAO;EACbE,SAAS,EAAET;AACb,CAAC,EACD;EACEM,IAAI,EAAE,QAAQ;EACdC,IAAI,EAAE,WAAW;EACjBE,SAAS,EAAER,SAAS;EACpBS,IAAI,EAAE;IAAEC,YAAY,EAAE,IAAI;IAAEC,IAAI,EAAE;EAAQ,CAAC;EAC3CJ,QAAQ,EAAE,oBAAoB;EAAG;EACjCK,QAAQ,EAAE,CACR;IACEP,IAAI,EAAE,aAAa;IACnBC,IAAI,EAAE,kBAAkB;IACxBE,SAAS,EAAEP;EACb,CAAC,EACD;IACEI,IAAI,EAAE,QAAQ;IACdC,IAAI,EAAE,aAAa;IACnBE,SAAS,EAAEA,CAAA,KAAM,MAAM,CAAC,2BAA2B;EACrD,CAAC,EACD;IACEH,IAAI,EAAE,MAAM;IACZC,IAAI,EAAE,WAAW;IACjBE,SAAS,EAAEA,CAAA,KAAM,MAAM,CAAC,yBAAyB;EACnD,CAAC,EACD;IACEH,IAAI,EAAE,QAAQ;IACdC,IAAI,EAAE,aAAa;IACnBE,SAAS,EAAEA,CAAA,KAAM,MAAM,CAAC,2BAA2B;EACrD,CAAC,EACD;IACEH,IAAI,EAAE,YAAY;IAClBC,IAAI,EAAE,iBAAiB;IACvBE,SAAS,EAAEA,CAAA,KAAM,MAAM,CAAC,+BAA+B;EACzD,CAAC;AAEL,CAAC,EACD;EACEH,IAAI,EAAE,SAAS;EACfC,IAAI,EAAE,YAAY;EAClBE,SAAS,EAAEN,UAAU;EACrBO,IAAI,EAAE;IAAEC,YAAY,EAAE,IAAI;IAAEC,IAAI,EAAE;EAAS,CAAC;EAC5CJ,QAAQ,EAAE,qBAAqB;EAAG;EAClCK,QAAQ,EAAE,CACR;IACEP,IAAI,EAAE,aAAa;IACnBC,IAAI,EAAE,mBAAmB;IACzBE,SAAS,EAAEL;EACb,CAAC,EACD;IACEE,IAAI,EAAE,QAAQ;IACdC,IAAI,EAAE,cAAc;IACpBE,SAAS,EAAEA,CAAA,KAAM,MAAM,CAAC,4BAA4B;EACtD,CAAC,EACD;IACEH,IAAI,EAAE,MAAM;IACZC,IAAI,EAAE,YAAY;IAClBE,SAAS,EAAEA,CAAA,KAAM,MAAM,CAAC,0BAA0B;EACpD,CAAC,EACD;IACEH,IAAI,EAAE,QAAQ;IACdC,IAAI,EAAE,cAAc;IACpBE,SAAS,EAAEA,CAAA,KAAM,MAAM,CAAC,4BAA4B;EACtD,CAAC,EACD;